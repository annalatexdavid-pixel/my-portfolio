# Copy this to .env.local for local dev, and set these in Vercel for production.

# Your GitHub username
NEXT_PUBLIC_GITHUB_OWNER=your-github-username

# The GitHub repo name where your portfolio code lives
NEXT_PUBLIC_GITHUB_REPO=portfolio-site

# From the GitHub OAuth App you create (see DEPLOY.md)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# A random secret string (32+ characters) — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEYSTATIC_SECRET=
